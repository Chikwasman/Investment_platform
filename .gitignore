# ============================================================
# TransAtlantia Trades — .gitignore
# ============================================================

# ---- ENVIRONMENT & SECRETS (NEVER commit these) ----
.env
.env.local
.env.production
.env.staging
*.env

# ---- NODE MODULES ----
node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock

# ---- UPLOADED USER FILES (private data) ----
uploads/
uploads/proofs/
uploads/kyc/

# ---- LOGS ----
logs/
*.log
*.log.*

# ---- OS FILES ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- EDITOR & IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- BUILD / DIST ----
dist/
build/
.cache/
.parcel-cache/
.next/
.nuxt/

# ---- RUNTIME ----
pids/
*.pid
*.seed
*.pid.lock
.node_repl_history

# ---- TESTING ----
coverage/
.nyc_output/
*.test.js.snap

# ---- PM2 (process manager) ----
.pm2/
ecosystem.config.js.bak

# ---- BACKUPS & ARCHIVES ----
*.tar.gz
*.zip
*.bak
*.backup
*.old

# ---- CERTIFICATES & KEYS ----
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ---- TEMPORARY ----
tmp/
temp/
.temp/
